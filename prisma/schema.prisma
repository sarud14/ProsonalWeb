generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WorkCaseStudy {
  id           String @id @default(cuid())
  slug         String @unique
  title        String
  status       String
  context      String
  problem      String
  constraints  String
  architecture String
  decisions    String
  impact       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model JournalPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  status      String
  content     String
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
